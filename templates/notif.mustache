<div class="akademikmonitor">
<div class="am-wrap">
  {{> local_akademikmonitor/sidebar }}

  <div class="am-content">
      <div class="am-mobile-topbar">
        <button type="button"
                class="am-hamburger"
                data-action="open-sidebar"
                aria-label="Buka menu">
          ☰
        </button>
        <div class="am-mobile-title">Menu Akademik</div>
      </div>
    <div class="am-breadcrumb">/ Pengaturan Notifikasi</div>
    <h2 class="am-h1">Pengaturan Notifikasi</h2>
    <div class="am-sub">Atur koneksi telegram dan aturan pengiriman notifikasi otomatis.</div>
    <div class="am-card">
      <div class="am-row" style="justify-content:space-between; align-items:center;">
        <div style="flex:1;">
          <div style="font-weight:700; margin-bottom:6px;">Export Link Telegram Siswa</div>
          <div class="am-help">
            Export data siswa berisi nama, NISN, nomor telepon, dan link hubungkan Telegram.
            Link ini dapat diberikan kepada wali murid agar wali murid dapat menghubungkan Telegram
            untuk menerima notifikasi siswa.
          </div>
        </div>

        <div>
          <a class="am-btn am-btn-primary" href="{{export_telegram_siswa_url}}">
            Export Excel
          </a>
        </div>
      </div>
    </div>
    <div class="am-card">
      <div class="am-row" style="justify-content:space-between;">
        <div style="flex:1;">
          <div style="font-weight:700; margin-bottom:6px;">Koneksi Bot Telegram</div>
          <label class="am-label">Token Bot</label>
          <input class="am-input" id="am-token" value="{{bot_token}}" placeholder="123456:ABCDEF...">
          <div class="am-help" id="am-token-status"></div>
        </div>
        <div style="display:flex; align-items:flex-end; gap:10px;">
          <button class="am-btn am-btn-ghost" type="button" data-action="check-telegram">Cek Koneksi</button>
          <button class="am-btn am-btn-primary" type="button" data-action="save-telegram">Simpan</button>
        </div>
      </div>
    </div>

    <div class="am-card">
      <div style="font-weight:700; margin-bottom:6px;">Notifikasi Otomatis</div>

      <table class="am-table">
        <thead>
          <tr>
            <th>Jenis Notifikasi</th>
            <th>Jam</th>
            <th>Trigger</th>
            <th>Penerima</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          {{#rules}}
          <tr>
            <td>{{label}}</td>
            <td>{{send_time}}</td>
            <td>
              <strong>H-{{offset_days}}</strong><br>
              <small style="color:#64748b;">{{keyword_label}}</small>
            </td>
            <td>{{recipients}}</td>
            <td>
            <button class="am-btn am-btn-secondary" type="button"
              data-action="edit-rule"
              data-id="{{id}}"
              data-label="{{label}}"
              data-offset="{{offset_days}}"
              data-time="{{send_time}}"
              data-keyword-label="{{keyword_label}}"
              data-keyword-help="{{keyword_help}}"
              data-recipients="{{recipients}}"
            >edit</button>

              <button class="am-btn am-btn-ghost" type="button"
                data-action="toggle-rule"
                data-id="{{id}}"
              >{{toggle_text}}</button>

              <span class="am-badge {{badge_class}}">{{badge_text}}</span>
            </td>
          </tr>
          {{/rules}}
          {{^rules}}
          <tr><td colspan="5" style="color:#888;">Belum ada rule. Dummy harusnya dibuat saat install.</td></tr>
          {{/rules}}
        </tbody>
      </table>
      
    </div>
    <div class="am-card">

    <div style="font-weight:700; margin-bottom:6px;">
      Pengiriman Laporan Telegram
    </div>

    <table class="am-table">

      <thead>
        <tr>
          <th>Jenis Laporan</th>
          <th>Hari</th>
          <th>Jam</th>
          <th>Penerima</th>
          <th>Aksi</th>
        </tr>
      </thead>

      <tbody>

        {{#reports}}
        <tr>

          <td>{{label}}</td>

          <td>{{schedule_label}}</td>

          <td>{{send_time}}</td>

          <td>{{recipients}}</td>

          <td>

          <button
              class="am-btn am-btn-secondary"
              type="button"
              data-action="edit-report"
              data-id="{{id}}"
              data-rule="{{rule_kode}}"
              data-label="{{label}}"
              data-time="{{send_time}}"
              data-offset="{{offset_days}}"
              data-days="{{offset_days}}"
              data-recipients="{{recipients_raw}}"
              data-schedule="{{schedule_label}}"
          >
              edit
          </button>

              <button
                class="am-btn am-btn-secondary"
                type="button"
                data-action="toggle-rule"
                data-id="{{id}}"
              >
                {{toggle_text}}
              </button>

              <span class="am-badge {{badge_class}}">
                {{badge_text}}
              </span>

          </td>

        </tr>
        {{/reports}}

      </tbody>

    </table>

  </div>
<div class="card mt-4">
    <div class="card-header">
        <h5>User Telegram Terhubung</h5>
    </div>

    <div class="card-body">

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nama</th>
                    <th>Telegram</th>
                    <th>Chat ID</th>
                    <th>Tersambung</th>
                    <th>Aksi</th>
                </tr>
            </thead>

            <tbody>
                {{#telegramusers}}
                <tr>
                    <td>{{fullname}}</td>
                    <td>@{{telegram_username}}</td>
                    <td>{{telegram_chat_id}}</td>
                    <td>{{linked_at}}</td>
                    <td>
                        <form method="post"
                              action="{{disconnect_action}}"
                              style="display:inline;"
                              onsubmit="return confirm('Putuskan sambungan Telegram ini?');">

                            <input type="hidden"
                                  name="id"
                                  value="{{disconnect_id}}">

                            <input type="hidden"
                                  name="sesskey"
                                  value="{{disconnect_sesskey}}">

                            <button type="submit"
                                    class="am-btn am-btn-danger">
                                Putuskan
                            </button>

                        </form>
                    </td>
                </tr>
                {{/telegramusers}}
            </tbody>
        </table>

    </div>
</div>

    <input type="hidden" id="am-sesskey" value="{{sesskey}}">
    <input type="hidden" id="am-ajaxurl" value="{{ajaxurl}}">

    <!-- MODAL EDIT -->
    <div class="am-modal-overlay" id="am-modal">
      <div class="am-modal">
        <div class="am-modal-header">
          <h3 class="am-modal-title">Edit Notifikasi Otomatis</h3>
          <button class="am-close" type="button" data-action="close-modal">✕</button>
        </div>

        <div class="am-grid">
          <div>
            <label class="am-label">Jenis Notifikasi</label>
              <div class="am-input" id="m-label-view" style="background:#f8fafc;color:#334155;">
                -
              </div>
              <div class="am-help">Jenis notifikasi sudah ditentukan oleh sistem.</div>
          </div>

          <div id="offset-wrap">
            <label class="am-label">Trigger (H-berapa)</label>
            <input class="am-input" id="m-offset" placeholder="contoh: 1 / 30">
          </div>

          <div>
            <label class="am-label">Jam dikirim</label>
            <input class="am-input" id="m-time" type="time" step="1" placeholder="07:00:00">
            <div class="am-help">Format: HH:MM:SS</div>
          </div>

          <div>
            <div id="report-days-wrap" style="display:none">

                <label>Hari Pengiriman</label>

                <div class="am-days-grid">

                <label><input class="report-day" type="checkbox" value="1"> Senin</label>

                <label><input class="report-day" type="checkbox" value="2"> Selasa</label>

                <label><input class="report-day" type="checkbox" value="3"> Rabu</label>

                <label><input class="report-day" type="checkbox" value="4"> Kamis</label>

                <label><input class="report-day" type="checkbox" value="5"> Jumat</label>

                <label><input class="report-day" type="checkbox" value="6"> Sabtu</label>

                <label><input class="report-day" type="checkbox" value="7"> Minggu</label>

                </div>

            </div>
            <div id ="keyword-wrap">
            <div class="am-input" id="m-keyword-view" style="background:#f8fafc;color:#334155;">
              -
            </div>
            <div class="am-help" id="m-keyword-help">
              Keyword dikunci oleh sistem.
            </div>
            </div>
          </div>

          <div>
            <label class="am-label">Penerima</label>
            <div class="am-checkboxes" id="m-recipients">
              <label><input type="checkbox" value="Siswa"> Siswa</label>
              <label><input type="checkbox" value="Guru"> Guru</label>
              <label><input type="checkbox" value="Wali Kelas"> Wali Kelas</label>
              <label><input type="checkbox" value="Admin"> Admin</label>
              <label><input type="checkbox" value="Kepala Sekolah"> Kepala Sekolah</label>
            </div>
          </div>

          <button class="am-btn am-btn-primary" type="button" data-action="save-rule">Simpan</button>
        </div>

        <input type="hidden" id="m-id" value="">
      </div>
    </div>
  </div>
</div>
</div>
