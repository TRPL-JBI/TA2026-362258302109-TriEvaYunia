<div class="akademikmonitor">
  <div class="am-wrap">
    {{> local_akademikmonitor/sidebar }}

    <div class="am-content">
      <div class="am-breadcrumb">/ Monitoring Presensi Guru</div>

      <div class="am-page-heading" style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;">
        <div>
          <h1 class="am-h1">Monitoring Presensi Guru</h1>
          <div class="am-sub">
            Pantau presensi guru berdasarkan aktivitas Attendance pada course kelas, baik dari input guru maupun presensi mandiri siswa.
          </div>
        </div>
      </div>

      <div class="am-card">
        <form method="get"
              action="{{filter_action}}"
              style="display:grid;grid-template-columns:repeat(4,minmax(180px,1fr));gap:12px;align-items:end;">

          <div>
            <label for="am-filter-ta" style="font-weight:600;margin-bottom:6px;display:block;">
              Tahun Ajaran
            </label>

            <select id="am-filter-ta"
                    name="tahunajaranid"
                    class="am-input"
                    onchange="this.form.kelasid.value='0'; this.form.teacherid.value='0'; this.form.submit();">

              {{#tahun_options}}
                <option value="{{id}}" {{#selected}}selected{{/selected}}>
                  {{nama}}
                </option>
              {{/tahun_options}}

              {{^tahun_options}}
                <option value="0">Belum ada tahun ajaran</option>
              {{/tahun_options}}
            </select>
          </div>

          <div>
            <label for="am-filter-semester" style="font-weight:600;margin-bottom:6px;display:block;">
              Semester
            </label>

            <select id="am-filter-semester"
                    name="semester"
                    class="am-input"
                    onchange="this.form.teacherid.value='0'; this.form.submit();">

              <option value="1" {{#is_semester_1}}selected{{/is_semester_1}}>Ganjil</option>
              <option value="2" {{#is_semester_2}}selected{{/is_semester_2}}>Genap</option>
            </select>
          </div>

          <div>
            <label for="am-filter-kelas" style="font-weight:600;margin-bottom:6px;display:block;">
              Kelas
            </label>

            <select id="am-filter-kelas"
                    name="kelasid"
                    class="am-input"
                    onchange="this.form.teacherid.value='0'; this.form.submit();">

              {{#kelas_options}}
                <option value="{{id}}" {{#selected}}selected{{/selected}}>
                  {{nama}}
                </option>
              {{/kelas_options}}

              {{^kelas_options}}
                <option value="0">Belum ada kelas</option>
              {{/kelas_options}}
            </select>
          </div>

          <div>
            <label for="am-filter-teacher" style="font-weight:600;margin-bottom:6px;display:block;">
              Nama Guru
            </label>

            <select id="am-filter-teacher"
                    name="teacherid"
                    class="am-input"
                    onchange="this.form.submit();">

              {{#teacher_options}}
                <option value="{{id}}" {{#selected}}selected{{/selected}}>
                  {{nama}}
                </option>
              {{/teacher_options}}

              {{^teacher_options}}
                <option value="0">Belum ada guru</option>
              {{/teacher_options}}
            </select>
          </div>
        </form>
      </div>

      <div class="am-card" style="margin-top:14px;">
        <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;">
          <div>
            <div style="font-size:13px;color:#64748b;">Filter aktif</div>
            <div style="font-weight:700;">
              {{selected_kelas_name}} - {{selected_teacher_name}}
            </div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <div class="am-mini-stat">
              <div class="am-mini-stat-label">Total Pertemuan</div>
              <div class="am-mini-stat-value">{{total_sessions}}</div>
            </div>

            <div class="am-mini-stat">
              <div class="am-mini-stat-label">Hadir</div>
              <div class="am-mini-stat-value">{{hadir_count}}</div>
            </div>

            <div class="am-mini-stat">
              <div class="am-mini-stat-label">Belum Diambil</div>
              <div class="am-mini-stat-value">{{belum_count}}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="am-card" style="margin-top:14px;">
        <div class="am-table-wrap">
            <table class="am-table am-presensi-table am-presensi-guru-table">
            <thead>
                <tr>
                <th>Jenis Presensi</th>
                <th>Tanggal Presensi</th>
                <th>Status Kehadiran</th>
                </tr>
            </thead>

            <tbody>
                {{#rows}}
                <tr>
                    <td data-label="Jenis Presensi">
                    <strong>{{jenis_presensi}}</strong>
                    </td>

                    <td data-label="Tanggal Presensi">
                    {{tanggal_presensi}}
                    </td>

                  <td data-label="Status Kehadiran">
                      <span class="am-presensi-badge {{status_kehadiran.class}}">
                          {{status_kehadiran.text}}
                      </span>
                  </td>
                </tr>
                {{/rows}}

                {{^rows}}
                <tr>
                    <td colspan="3" class="am-empty-state" style="text-align:center;padding:24px;">
                    Belum ada sesi presensi untuk guru dan kelas yang dipilih.
                    </td>
                </tr>
                {{/rows}}
            </tbody>
            </table>
        </div>

        {{^rows}}
          <div class="am-empty-state" style="margin-top:12px;">
            Belum ada sesi presensi untuk guru dan kelas yang dipilih.
            Pastikan guru tersebut mengajar course hasil generate dan aktivitas Attendance sudah memiliki sesi.
          </div>
        {{/rows}}
      </div>

      <div class="am-card" style="margin-top:14px;">
        <strong>Keterangan:</strong>

        <div style="margin-top:10px;display:grid;gap:8px;">
          <div>
            <span class="am-presensi-badge am-presensi-present">Hadir</span>
            <span style="margin-left:8px;color:#475569;font-size:13px;">
              Guru menginputkan presensi atau minimal ada satu siswa yang melakukan presensi mandiri.
            </span>
          </div>

          <div>
            <span class="am-presensi-badge am-presensi-empty">Belum Diambil</span>
            <span style="margin-left:8px;color:#475569;font-size:13px;">
              Belum ada input presensi dari guru dan belum ada siswa yang melakukan presensi.
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>